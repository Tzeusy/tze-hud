+# Virtual-key codes for the focus/resize chords (hud-v4k1h / hud-v0cal).
+_VK_CONTROL = 0x11
+_VK_SHIFT = 0x10
+_VK_TAB = 0x09
+_VK_OEM_PLUS = 0xBB   # '='/'+' key -> physical KeyCode::Equal
+_VK_OEM_MINUS = 0xBD  # '-'/'_' key -> physical KeyCode::Minus
+
+
+def build_resize_focus_plan(
+    portal_x: float,
+    portal_y: float,
+    *,
+    tab_width: Optional[float] = None,
+    tab_height: Optional[float] = None,
+) -> list[dict[str, Any]]:
+    """Focus the portal, then exercise the focused-portal resize hotkeys and the
+    Tab / Shift+Tab focus-traversal chord via REAL virtual-key injection.
+
+    Validates hud-v4k1h (Ctrl+'='/Ctrl+'+' grow, Ctrl+'-' shrink on the focused
+    portal) and hud-v0cal (#980 pointer-independent keyboard focus traversal).
+    Unlike the Unicode `text` action these land as physical key codes the
+    runtime handlers match on.
+    """
+    input_rect, _output_rect = portal_pane_rects()
+    composer_x = portal_x + input_rect.x + input_rect.w / 2.0
+    composer_y = portal_y + input_rect.y + min(input_rect.h - 10.0, 72.0)
+    # Re-focus (click) before each chord group: a click re-asserts overlay
+    # foreground + keyboard focus, which synthetic chords need (SendInput keyboard
+    # routes to the focused window).  NOTE: synthetic key injection only lands on
+    # an UNLOCKED, quiescent desktop — a locked/secure desktop returns
+    # ERROR_ACCESS_DENIED and other foreground windows can intercept the keys, so
+    # the authoritative focused-portal resize check remains a real operator keypress.
+    focus_click = {"kind": "click", "label": "focus-composer", "x": composer_x, "y": composer_y}
+    return [
+        focus_click,
+        {"kind": "chord", "label": "ctrl-equal-grow", "mods": [_VK_CONTROL], "key": _VK_OEM_PLUS, "count": 3},
+        dict(focus_click),
+        {"kind": "chord", "label": "ctrl-minus-shrink", "mods": [_VK_CONTROL], "key": _VK_OEM_MINUS, "count": 5},
+        dict(focus_click),
+        {"kind": "chord", "label": "tab-focus-forward", "mods": [], "key": _VK_TAB, "count": 1},
+        dict(focus_click),
+        {"kind": "chord", "label": "shift-tab-focus-back", "mods": [_VK_SHIFT], "key": _VK_TAB, "count": 1},
+    ]
+
